# PassPoint Demo — pure frontend build (no backend/server/database).
# Only VITE_-prefixed vars are read (Vite bundles them into the client
# JS), so treat everything here as PUBLIC, not secret. Fine for a demo;
# don't reuse real production keys here.

# Options: openai | groq | openrouter
VITE_AI_PROVIDER=groq

# --- Groq (recommended for free tier) ---
# Get a free key at https://console.groq.com/keys
VITE_GROQ_API_KEY=gsk_your_groq_key_here
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenRouter (alternative free tier) ---
# Get a free key at https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
VITE_OPENROUTER_MODEL=google/gemma-4-31b-it:free

# --- OpenAI (paid) ---
VITE_OPENAI_API_KEY=sk-proj-your_openai_key_here
VITE_OPENAI_MODEL=gpt-4.1

# --- Vision (homework marking) — optional overrides ---
VITE_GROQ_VISION_MODEL=
VITE_OPENAI_VISION_MODEL=
VITE_OPENROUTER_VISION_MODEL=

# --- High-quality text-to-speech (falls back to the browser voice without this) ---
VITE_TTS_PROVIDER=openai
VITE_OPENAI_TTS_MODEL=tts-1-hd
VITE_OPENAI_TTS_VOICE=nova
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
VITE_ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- Real photos/videos (kindergarten object/letter scenes) ---
# Pexels is free and generous: https://www.pexels.com/api
VITE_PEXELS_API_KEY=
VITE_UNSPLASH_ACCESS_KEY=
VITE_VECTEEZY_API_KEY=

VITE_APP_NAME=PassPoint AI

# Note: signup/login/OTP and homework-report "email" are all simulated in
# the browser (localStorage) — there's no real account database or SMTP
# sending. OTP codes are shown on-screen instead of emailed.
