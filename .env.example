# PassPoint Demo — AI provider configuration
# Pick ONE provider and fill in the key for that provider only.

# Options: openai | groq | openrouter
AI_PROVIDER=groq

# --- Groq (recommended for free tier) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenRouter (alternative free tier) ---
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# --- OpenAI (paid) ---
OPENAI_API_KEY=sk-proj-your_openai_key_here
OPENAI_MODEL=gpt-4.1

PORT=5001

# --- Vision (homework marking) ---
# Optional overrides. Defaults: Groq → meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_MODEL=
OPENAI_VISION_MODEL=
OPENROUTER_VISION_MODEL=

# --- High-quality text-to-speech (so the AI tutor stops sounding robotic) ---
# Without this, the app falls back to the browser's built-in voice (Web
# Speech API). Set ONE of OPENAI_API_KEY or ELEVENLABS_API_KEY to upgrade.
TTS_PROVIDER=openai
# OpenAI options (uses your existing OPENAI_API_KEY):
OPENAI_TTS_MODEL=tts-1-hd
OPENAI_TTS_VOICE=nova
# ElevenLabs options (sign up free at https://elevenlabs.io):
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- Real photos (kindergarten object/body-part/letter scenes) ---
# Set ONE of these so /api/image and /api/images return real stock
# photos instead of falling back to emoji. Pexels is free and generous:
# https://www.pexels.com/api  ·  Unsplash: https://unsplash.com/developers
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
VECTEEZY_API_KEY=

# --- Email (parent reports) ---
# Get a free Resend API key at https://resend.com (100 emails/day free).
# Without this key, the /api/report endpoint returns the HTML preview
# instead of sending — the demo still works without setting it up.
RESEND_API_KEY=
REPORT_FROM_ADDRESS=PassPoint AI <onboarding@resend.dev>

# --- Email (SMTP — also powers signup OTP + password reset emails) ---
# A Gmail App Password is the easiest way to get this working locally:
# https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=
EMAIL_APP_PASSWORD=
APP_NAME=PassPoint AI
SUPPORT_EMAIL=

# How long a signup/reset OTP stays valid, in minutes.
OTP_EXPIRY_MINUTES=10

# --- MongoDB Database ---
# Users, OTP + password-reset state all live here (see models/User.js and
# models/EmailVerification.js). Supabase is no longer used for auth.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.qvswvrp.mongodb.net/passpointai-backend?retryWrites=true&w=majority&appName=Cluster0

# --- JWT (custom auth sessions) ---
# Any long random string works. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=30d
