<!doctype html>
<html>
  <body style="margin:0;padding:0;background:#eef0fb;font-family:-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;color:#0f172a;">
    <div style="max-width:480px;margin:32px auto;background:#ffffff;border-radius:20px;overflow:hidden;box-shadow:0 12px 32px rgba(79,70,229,0.16);">
      <div style="background-color:#4338ca;background-image:linear-gradient(135deg,#7c3aed,#4338ca);padding:36px 32px 30px;text-align:center;">
        <div style="display:inline-block;background:#ffffff;border-radius:14px;padding:8px 14px;box-shadow:0 6px 18px rgba(0,0,0,0.15);">
          <img src="cid:pplogo" alt="{{appName}}" height="32" style="display:block;height:32px;width:auto;border:0;" />
        </div>
        <div style="font-size:11px;color:rgba(255,255,255,0.78);margin-top:16px;text-transform:uppercase;letter-spacing:2px;font-weight:700;">
          Learn Smarter, Achieve Greater
        </div>
      </div>

      <div style="padding:36px 32px;">
        <h1 style="font-size:19px;margin:0 0 10px;color:#0f172a;font-weight:800;">{{heading}}</h1>
        <p style="margin:0 0 26px;color:#475569;line-height:1.6;font-size:14px;">{{subheading}}</p>

        <div style="text-align:center;margin:8px 0 26px;">
          <div style="display:inline-block;background:#f5f3ff;border:1.5px dashed #7c3aed;border-radius:14px;padding:16px 30px;">
            <span style="font-size:32px;font-weight:800;letter-spacing:9px;color:#4338ca;font-family:'Courier New',monospace;">{{otp}}</span>
          </div>
        </div>

        <p style="margin:0;color:#64748b;font-size:13px;text-align:center;line-height:1.6;">
          This code expires in {{expiryMinutes}} minutes.<br />
          If you didn't request this, you can safely ignore this email.
        </p>
      </div>

      <div style="background:#f8fafc;padding:18px 32px;text-align:center;color:#94a3b8;font-size:12px;border-top:1px solid #eef2ff;">
        Need help? <a href="mailto:{{supportEmail}}" style="color:#7c3aed;text-decoration:none;">{{supportEmail}}</a>
        <br />© {{year}} {{appName}}. All rights reserved.
      </div>
    </div>
  </body>
</html>
